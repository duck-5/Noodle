# Moodle Auth
MOODLE_URL=https://moodle.tau.ac.il
MOODLE_TOKEN=your_moodle_api_key_here

# Spreadsheet Config (Defaults to these if omitted)
SPREADSHEET_NAME=University Tracker
WORKSHEET_NAME=Year1-SemesterB

# Panopto Auth
PANOPTO_URL=https://tau.cloud.panopto.eu
PANOPTO_USER=your_username
PANOPTO_PASS=your_password
PANOPTO_PID=your_student_id

# Moodle Config: Comma-separated list of Course IDs you want to sync this semester
MOODLE_COURSES=0321110401, 0321183601

# Panopto Config: Map your courses cleanly using PANOPTO_COURSE_{ID}
PANOPTO_COURSE_0321110401=https://tau.cloud.panopto.eu/Panopto/Pages/Sessions/List.aspx#view=0&folderID="uuid..."
PANOPTO_COURSE_0321183601=https://tau.cloud.panopto.eu/Panopto/Pages/Sessions/List.aspx#view=0&folderID="uuid..."
